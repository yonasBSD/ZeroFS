{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/docs", "destination": "https://docs-origin.zerofs.net/" },
    { "source": "/docs/:path*", "destination": "https://docs-origin.zerofs.net/:path*" }
  ],
  "redirects": [
    {
      "source": "/:path((?!docs|assets|favicon\\.png|robots\\.txt|sitemap\\.xml).+)",
      "destination": "/docs/:path",
      "permanent": true
    }
  ]
}
